{
  "name": "Sherlock Development",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "pip install -e . && pip install pytest pytest-xdist",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "sherlock_project/sherlock.py"
      ]
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Application",
      "onAutoForward": "notify"
    }
  }
}
